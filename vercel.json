{
  "version": 2,
  "functions": {
    "backend/main.py": {
      "maxDuration": 10,
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/((?!assets|favicon|icon-).*)",
      "destination": "frontend/dist/index.html"
    }
  ]
}
